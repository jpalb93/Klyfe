<!DOCTYPE html>
<html lang="pt-BR">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<!-- Scroll Spy Nav (lateral) -->
<nav class="scroll-nav">
    <div class="dot active" data-target="#hero" data-label="Início"></div>
    <div class="dot" data-target="#solucoes" data-label="Soluções"></div>
    <div class="dot" data-target="#empresa" data-label="A Empresa"></div>
    <div class="dot" data-target="#diferenciais" data-label="Diferenciais"></div>
    <div class="dot" data-target="#projetos" data-label="Projetos"></div>
    <div class="dot" data-target="#blog" data-label="Blog"></div>
    <div class="dot" data-target="#faq" data-label="FAQ"></div>
</nav>

<main>
    <% const homePrefix = getHomePrefix(); %>


<!-- ═══ HERO ═══ -->
<section class="hero bg-blueprint" id="hero">
    <div class="container" style="position:relative">
        <div class="hero-content fade-in">
            <div style="font-family:var(--font-mono);color:var(--text-muted);font-size:0.85rem;margin-bottom:1.5rem">KLYFE ELECTRIC · <%= cityData.name.toUpperCase() %></div>
            <h1 style="font-size:4.5rem;line-height:1.05">Engenharia &<br>
                <span style="font-family:var(--font-heading);font-weight:400;font-style:italic;font-size:4rem">Energia <%= cityData.preposition %></span><br>
                <span style="color:var(--accent-primary);font-size:5.5rem"><%= cityData.name %>.</span>
            </h1>

            <p class="hero-subtitle">Soluções elétricas, automação e energia solar <%= cityData.preposition %> <%= cityData.name %> e região. Projetos sob medida, execução de precisão.</p>



            <div style="display:flex;gap:1rem;flex-wrap:wrap">
                <a href="/contato" class="btn btn-primary">Solicitar Orçamento</a>
                <a href="/projetos" class="btn btn-ghost"><i class="fas fa-play-circle"></i> Ver Projetos</a>
            </div>
        </div>
    </div>
        <!-- Stats removidos a pedido do usuário -->

</section>


<!-- ═══ MARQUEE TICKER ═══ -->
<div class="marquee-wrap">
    <div class="marquee-track">
        <span>Soluções Elétricas</span><div class="dot">⚡</div>
        <span>Automação Residencial</span><div class="dot">⚙️</div>
        <span>Energia Solar</span><div class="dot">☀️</div>
        <span>Projetos com ART</span><div class="dot">📐</div>
        <span>NR-10 · SPDA</span><div class="dot">🛡️</div>
        <span>Campina Grande</span><div class="dot">📍</div>
        <span>João Pessoa</span><div class="dot">📍</div>
        <!-- Duplicado para loop infinito -->
        <span>Soluções Elétricas</span><div class="dot">⚡</div>
        <span>Automação Residencial</span><div class="dot">⚙️</div>
        <span>Energia Solar</span><div class="dot">☀️</div>
        <span>Projetos com ART</span><div class="dot">📐</div>
        <span>NR-10 · SPDA</span><div class="dot">🛡️</div>
        <span>Campina Grande</span><div class="dot">📍</div>
        <span>João Pessoa</span><div class="dot">📍</div>
    </div>
</div>


<!-- Divisor de Identidade -->
<div class="container" style="display:flex; justify-content:center; margin: 4rem 0 -2rem 0; opacity:0.3">
    <div style="width:2px; height:60px; background:linear-gradient(transparent, var(--accent-solar), transparent)"></div>
</div>

<!-- ═══ SOLUÇÕES (Reveal Cards) ═══ -->
<section class="section-padding" id="solucoes">
    <div class="container">
        <div class="section-separator fade-in"><%- include('partials/symbol') %> <span>01 SOLUÇÕES</span></div>
        <h2 class="fade-in" style="margin-bottom:1rem">SOLUÇÕES DE<br><em style="color:var(--accent-primary);font-style:italic">ALTO IMPACTO.</em></h2>
        <p class="section-intro fade-in" style="color: var(--text-muted); margin-bottom: 3rem; max-width: 600px; line-height: 1.6;">Oferecemos um portfólio completo de engenharia para viabilizar seus projetos com máxima economia e eficiência. Nossos serviços cobrem desde laudos técnicos e homologações de energia solar até automação residencial inteligente e instalações elétricas industriais.</p>
        <div class="grid grid-cols-3">
            <% // O helper getServicesByCategory agora vem do middleware no routes/index.js %>


            <% if (isServiceEnabled('engenharia')) { %>
            <div class="reveal-card eng fade-in">
                <a href="<%= homePrefix %>/solucoes/engenharia" class="card-top-link" style="text-decoration: none; color: inherit; display: block;">
                    <div class="card-top">
                        <div class="card-icon" style="background:rgba(245,200,66,0.1);color:var(--accent-primary)"><i class="fas fa-hard-hat"></i></div>
                        <h3>ENGENHARIA ELÉTRICA</h3>
                        <p style="color:var(--text-muted);font-size:0.9rem;margin-top:0.5rem">Projetos, laudos e consultoria com responsabilidade técnica.</p>
                    </div>
                </a>
                <div class="card-bottom">
                    <div class="card-bottom-inner">
                        <h4 style="font-family: var(--font-heading); color: var(--text-main); margin-bottom: 1rem; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.5px;">Serviços & Laudos</h4>
                        <ul>
                            <li><a href="<%= homePrefix %>/solucoes/engenharia/projeto-eletrico">Projeto Elétrico (BIM 3D)</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/engenharia/laudos-eletricos">Laudo de NR-10 e SPDA</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/engenharia/projeto-subestacao">Projeto de Subestações</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/engenharia/pericia-furto-energia">Perícias de TOI e Danos</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/engenharia/viabilidade-carregador-veicular">Viabilidade de Recarga EV</a></li>
                        </ul>
                        <a href="<%= homePrefix %>/solucoes/engenharia" class="btn-ver-mais" style="color: var(--accent-primary); font-family: var(--font-heading); text-transform: uppercase; font-weight: bold; font-size: 0.9rem; margin-top: 1rem; display: flex; align-items: center; gap: 0.5rem; text-decoration: none;">
                            Ver todas as soluções <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
            <% } %>

            <% if (isServiceEnabled('solar')) { %>
            <div class="reveal-card solar fade-in">
                <a href="<%= homePrefix %>/solucoes/solar" class="card-top-link" style="text-decoration: none; color: inherit; display: block;">
                    <div class="card-top">
                        <div class="card-icon" style="background:rgba(255,107,43,0.1);color:var(--accent-solar)"><i class="fas fa-sun"></i></div>
                        <h3>ENERGIA SOLAR</h3>
                        <p style="color:var(--text-muted);font-size:0.9rem;margin-top:0.5rem">Sistemas fotovoltaicos para redução de custos.</p>
                    </div>
                </a>
                <div class="card-bottom">
                    <div class="card-bottom-inner">
                        <h4 style="font-family: var(--font-heading); color: var(--text-main); margin-bottom: 1rem; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.5px;">Geração Solar</h4>
                        <ul>
                            <li><a href="<%= homePrefix %>/solucoes/solar#residencial">Projetos Solares Residenciais</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/solar#comercial">Sistemas Fotovoltaicos Comerciais</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/solar#homologacao">Homologação na Energisa</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/solar#roi">Estudo de Viabilidade & ROI</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/solar#manutencao">Manutenção de Painéis</a></li>
                        </ul>
                        <a href="<%= homePrefix %>/solucoes/solar" class="btn-ver-mais" style="color: var(--accent-solar); font-family: var(--font-heading); text-transform: uppercase; font-weight: bold; font-size: 0.9rem; margin-top: 1rem; display: flex; align-items: center; gap: 0.5rem; text-decoration: none;">
                            Ver todas as soluções <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
            <% } %>

            <% if (isServiceEnabled('automacao')) { %>
            <div class="reveal-card auto fade-in">
                <a href="<%= homePrefix %>/solucoes/automacao" class="card-top-link" style="text-decoration: none; color: inherit; display: block;">
                    <div class="card-top">
                        <div class="card-icon" style="background:rgba(42,245,160,0.1);color:var(--accent-secondary)"><i class="fas fa-cog"></i></div>
                        <h3>AUTOMAÇÃO SMART</h3>
                        <p style="color:var(--text-muted);font-size:0.9rem;margin-top:0.5rem">Controle e inteligência residencial e industrial.</p>
                    </div>
                </a>
                <div class="card-bottom">
                    <div class="card-bottom-inner">
                        <h4 style="font-family: var(--font-heading); color: var(--text-main); margin-bottom: 1rem; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.5px;">Sistemas Inteligentes</h4>
                        <ul>
                            <li><a href="<%= homePrefix %>/solucoes/automacao/automacao-residencial">Automação Residencial (Smart Home)</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/automacao#clima">Controle de Climatização e Luzes</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/automacao#audio">Integração de Áudio e Home Theater</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/eletrica/projeto-rede">Infraestrutura de Redes e Wi-Fi</a></li>
                            <li><a href="<%= homePrefix %>/solucoes/automacao#processos">Automação de Processos</a></li>
                        </ul>
                        <a href="<%= homePrefix %>/solucoes/automacao" class="btn-ver-mais" style="color: var(--accent-secondary); font-family: var(--font-heading); text-transform: uppercase; font-weight: bold; font-size: 0.9rem; margin-top: 1rem; display: flex; align-items: center; gap: 0.5rem; text-decoration: none;">
                            Ver todas as soluções <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
            <% } %>
        </div>

    </div>
</section>




<!-- ═══ SERVIÇOS DO DIA A DIA ═══ -->
<% if (isServiceEnabled('eletrica')) { %>
<section class="section-padding" style="background:var(--bg-secondary)">
    <div class="container fade-in">
        <div class="section-separator"><%- include('partials/symbol') %> <span>SERVIÇOS ELÉTRICOS</span></div>
        <h2 style="margin-bottom:0.5rem">SERVIÇOS DO</h2>
        <h2 style="margin-bottom:3rem;color:var(--accent-primary)"><em style="font-style:italic">DIA A DIA.</em></h2>
        <div class="feature-grid">
            <% 
               const dailyKeys = [
                 'tomadas-interruptores',
                 'iluminacao',
                 'chuveiro-eletrico',
                 'ventiladores',
                 'quadro-distribuicao',
                 'fiacao-cabeamento',
                 'ar-condicionado',
                 'carregador-veicular'
               ];
               const activeDailyServices = dailyKeys.filter(key => isServiceEnabled(key));
               activeDailyServices.forEach(key => {
                 const svc = (cityData.services && cityData.services[key]) || locations.default.services[key];
            %>
                <div class="feature-card" style="text-align:left">
                    <div class="icon" style="background:rgba(245,200,66,0.1);color:var(--accent-primary);margin:0 0 1rem 0">
                        <i class="fas <%= svc.icon || 'fa-plug' %>"></i>
                    </div>
                    <h4><%= svc.label %></h4>
                    <p><%= svc.summary || svc.painPoint || 'Instalação e manutenção técnica especializada.' %></p>
                </div>
            <% }) %>
        </div>
        <div style="text-align:center;margin-top:3rem">
            <a href="<%= homePrefix %>/solucoes/eletrica" class="btn btn-outline">Ver catálogo completo de serviços →</a>
        </div>
    </div>
</section>
<% } %>

<!-- ═══ SOBRE ═══ -->
<section class="section-padding" style="background:var(--bg-secondary)" id="empresa">
    <div class="container grid grid-cols-2" style="align-items:center;gap:4rem">
        <div class="fade-in" style="background:linear-gradient(135deg,var(--border-color),var(--bg-primary));border-radius:12px;height:400px;display:flex;align-items:center;justify-content:center; padding: 4rem;">
            <div style="opacity: 0.15; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                <%- include('partials/symbol') %>
            </div>
        </div>
        <div class="fade-in">
            <div class="section-separator"><%- include('partials/symbol') %> <span>02 A EMPRESA</span></div>
            <h2>Sua empresa de<br>eletricidade <%= cityData.preposition %><br><span style="color:var(--accent-primary)"><%= cityData.name %>.</span></h2>
            <p style="margin:1.5rem 0;color:var(--text-muted);line-height:1.8">Elevamos o padrão da engenharia elétrica na Paraíba. Unimos técnica rigorosa, equipamentos premium e segurança máxima em todos os projetos que entregamos em <%= cityData.name %> e região.</p>

            <a href="/quem-somos" class="btn btn-outline">Conheça nossa história →</a>
        </div>

    </div>
</section>

<!-- ═══ DIFERENCIAIS ═══ -->
<section class="section-padding bg-blueprint" id="diferenciais">
    <div class="container fade-in">
        <h2 style="text-align:center;margin-bottom:1rem;color:var(--accent-primary)"><em style="font-style:italic">OPERACIONAIS.</em></h2>
        <p class="fade-in" style="color: var(--text-muted); text-align: center; max-width: 600px; margin: 0 auto 3rem auto; line-height: 1.6;">Nossa equipe de engenharia atua em conformidade com as normas nacionais de segurança e regulamentos das concessionárias locais. Garantimos alta precisão em todas as etapas de sua obra.</p>
        <div class="grid grid-cols-3" style="gap:1.5rem">
            <div class="bracket-box"><h4 style="margin-bottom:0.5rem"><i class="fas fa-file-signature" style="color:var(--accent-primary);margin-right:0.5rem"></i> ART em toda obra</h4><p style="color:var(--text-muted);font-size:0.9rem">Garantia de responsabilidade técnica em 100% dos serviços.</p></div>
            <div class="bracket-box"><h4 style="margin-bottom:0.5rem"><i class="fas fa-tools" style="color:var(--accent-primary);margin-right:0.5rem"></i> Normas ABNT/NR-10</h4><p style="color:var(--text-muted);font-size:0.9rem">Projetos e execuções conforme todas as normas vigentes.</p></div>
            <div class="bracket-box"><h4 style="margin-bottom:0.5rem"><i class="fas fa-shield-alt" style="color:var(--accent-primary);margin-right:0.5rem"></i> Equipe certificada</h4><p style="color:var(--text-muted);font-size:0.9rem">Profissionais com certificações técnicas reconhecidas.</p></div>
            <div class="bracket-box"><h4 style="margin-bottom:0.5rem"><i class="fas fa-headset" style="color:var(--accent-primary);margin-right:0.5rem"></i> Suporte pós-obra</h4><p style="color:var(--text-muted);font-size:0.9rem">Acompanhamento dedicado após a entrega do projeto.</p></div>
            <div class="bracket-box"><h4 style="margin-bottom:0.5rem"><i class="fas fa-dollar-sign" style="color:var(--accent-primary);margin-right:0.5rem"></i> Projetos para financiamento</h4><p style="color:var(--text-muted);font-size:0.9rem">Documentação pronta para aprovação de crédito.</p></div>
            <div class="bracket-box"><h4 style="margin-bottom:0.5rem"><i class="fas fa-map-marked-alt" style="color:var(--accent-primary);margin-right:0.5rem"></i> Atendimento regional</h4><p style="color:var(--text-muted);font-size:0.9rem">CG, JP e toda a Paraíba com logística ágil.</p></div>
        </div>
    </div>
</section>

<!-- ═══ DEPOIMENTOS ═══ -->
<section class="section-padding" style="background:var(--bg-secondary)">
    <div class="container fade-in">
        <h2 style="text-align:center;margin-bottom:0.5rem">O que dizem nossos clientes</h2>
        <p style="text-align:center;color:var(--text-muted);margin-bottom:3rem">★★★★★ 5,0 · 120 avaliações no Google</p>
        <div class="grid grid-cols-3">
            <div class="testimonial-card"><div class="quote">"</div><p>Excelente atendimento, equipe profissional e obra entregue no prazo. Recomendo a todos em Campina Grande!</p><div class="author">Roberto M. — Campina Grande</div></div>
            <div class="testimonial-card"><div class="quote">"</div><p>Instalaram meu sistema solar em tempo recorde. Já estou economizando 90% na conta de luz desde o primeiro mês.</p><div class="author">Ana Paula S. — João Pessoa</div></div>
            <div class="testimonial-card"><div class="quote">"</div><p>A automação da minha casa ficou incrível. Controlo tudo pelo celular. Equipe técnica de primeiro mundo.</p><div class="author">Carlos H. — Campina Grande</div></div>
        </div>
    </div>
</section>

<!-- ═══ PROJETOS BENTO GRID ═══ -->
<section class="section-padding bg-blueprint" id="projetos">
    <div class="container fade-in">
        <div class="section-separator"> <%- include('partials/symbol') %> <span>05 PROJETOS</span></div>
        <h2>ENGENHARIA EM<br><em style="color:var(--accent-primary);font-style:italic">MOVIMENTO.</em></h2>
        <div class="grid grid-cols-1" style="margin-top:3rem">
            <!-- Case Real: HU -->
            <a href="/projetos/avaliacao-qualidade-instalacoes-eletricas-hu" style="text-decoration: none; color: inherit;" aria-label="Ver detalhes do projeto de avaliação técnica no Hospital Universitário de Campina Grande">
                <div class="bento-item span-2" role="img" aria-label="Foto técnica das instalações elétricas do Hospital Universitário" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.8)), url('/img/projetos/projeto-hu-2026-1.webp'); background-size: cover; background-position: center; min-height: 400px; display: flex; align-items: flex-end; border: 1px solid var(--border-color); cursor: pointer; transition: transform 0.3s ease;">
                    <div class="bento-info" style="width: 100%; padding: 3rem; background: linear-gradient(transparent, rgba(0,0,0,0.9));">
                        <span class="badge-mono" style="background:var(--accent-primary);color:var(--bg-primary)">Engenharia & Inspeção</span>
                        <h3 style="margin-top:1rem;font-size:2.5rem; color: #fff;">AVALIAÇÃO TÉCNICA HU</h3>
                        <p style="color:rgba(255,255,255,0.7);font-size:1.1rem; max-width: 600px; margin-top: 0.5rem;">Hospital Universitário (HU), Campina Grande · 2026. Laudo completo de instalações, termografia e conformidade normativa.</p>
                        <div style="margin-top: 1.5rem; display: flex; gap: 1rem;">
                            <span class="badge-mono" style="background: transparent; border: 1px solid rgba(255,255,255,0.3); color: #fff;">NR-10</span>
                            <span class="badge-mono" style="background: transparent; border: 1px solid rgba(255,255,255,0.3); color: #fff;">Termografia</span>
                            <span class="badge-mono" style="background: transparent; border: 1px solid rgba(255,255,255,0.3); color: #fff;">NBR 5410</span>
                        </div>
                    </div>
                </div>
            </a>

        </div>
        <div style="text-align:center;margin-top:3rem"><a href="/projetos" class="btn btn-outline">Ver portfólio completo →</a></div>
    </div>
</section>


<!-- ═══ BLOG ═══ -->
<section class="section-padding" style="background:var(--bg-secondary)" id="blog">
    <div class="container fade-in">
        <div class="section-separator"><%- include('partials/symbol') %> <span>06 BLOG TÉCNICO</span></div>
        <h2>BLOG<br><em style="color:var(--accent-primary);font-style:italic">TÉCNICO.</em></h2>
        <div class="grid grid-cols-2" style="margin-top:3rem">
            <a href="<%= homePrefix %>/blog" class="bracket-box" style="display:flex;flex-direction:column">

                <span class="badge-mono" style="background:var(--accent-solar);color:var(--bg-primary);align-self:flex-start;margin-bottom:1rem">Solar · 5 min</span>
                <h3 style="flex-grow:1;margin-bottom:1rem">Energia Solar <%= cityData.preposition %> <%= cityData.name %>: Por que a Klyfe Electric é referência na Paraíba em 2025</h3>

                <span style="color:var(--accent-solar);font-family:var(--font-heading);text-transform:uppercase">Ler artigo →</span>
            </a>
            <a href="<%= homePrefix %>/blog" class="bracket-box" style="display:flex;flex-direction:column">
                <span class="badge-mono" style="background:var(--accent-primary);color:var(--bg-primary);align-self:flex-start;margin-bottom:1rem">Elétrica · 4 min</span>
                <h3 style="flex-grow:1;margin-bottom:1rem">Eletricista <%= cityData.preposition %> <%= cityData.name %>: Riscos de Fiações Antigas e a Solução da Klyfe Electric</h3>

                <span style="color:var(--accent-primary);font-family:var(--font-heading);text-transform:uppercase">Ler artigo →</span>
            </a>
        </div>

    </div>
</section>

<!-- ═══ CTA BANNER ═══ -->
<section class="cta-banner">
    <div class="container fade-in" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:2rem">
        <div>
            <h2>Pronto para reduzir sua<br>conta de energia?</h2>
            <p>Solicite um orçamento grátis de energia solar, automação ou soluções elétricas <%= cityData.preposition %> <%= cityData.name %> e toda a Paraíba.</p>

        </div>
        <div style="display:flex;gap:1rem;flex-wrap:wrap">
            <a href="/contato" class="btn-dark">Solicitar Orçamento</a>
            <% const waMsgHome = (typeof cityData !== 'undefined' && cityData.whatsappMessage) ? cityData.whatsappMessage : 'Olá! Gostaria de solicitar um orçamento.'; %>
            <a href="https://wa.me/5583991330972?text=<%= encodeURIComponent(waMsgHome) %>" target="_blank" rel="noopener" class="btn-dark" style="background:transparent;border:2px solid var(--bg-primary);color:var(--bg-primary)"><i class="fab fa-whatsapp"></i> Ligue Agora</a>
        </div>

    </div>
</section>

<!-- ═══ FAQ ═══ -->
<section class="section-padding" id="faq">
    <div class="container fade-in" style="max-width:800px">
        <h2 style="text-align:center;margin-bottom:3rem">Perguntas Frequentes</h2>
        <div class="faq-item"><div class="faq-question">Quanto custa uma instalação elétrica? <i class="fas fa-plus"></i></div><div class="faq-answer"><div class="faq-answer-inner"><p>O custo varia conforme o tamanho e complexidade do projeto. Realizamos uma visita técnica para levantamento e apresentamos um orçamento detalhado sem compromisso.</p></div></div></div>
