<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head', { title: title, description: description, canonical: canonical, jsonLd: jsonLd }) %>
    <style>
        /* Scoped styles for premium blog post reader */
        .post-layout {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 4rem;
            margin-top: 3rem;
        }

        .post-main {
            min-width: 0; /* Prevents flex/grid overflow */
        }

        .post-sidebar {
            position: sticky;
            top: 100px;
            align-self: start;
        }

        .post-content-body {
            font-size: 1.1rem;
            line-height: 1.8;
            color: rgba(232, 234, 240, 0.92);
        }

        .post-content-body p {
            margin-bottom: 1.75rem;
        }

        .post-content-body h2 {
            font-family: var(--font-heading);
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-main);
            margin-top: 3rem;
            margin-bottom: 1.25rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 0.5rem;
        }

        .post-content-body h3 {
            font-family: var(--font-heading);
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--text-main);
            margin-top: 2rem;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .post-content-body ul, .post-content-body ol {
            margin-bottom: 2rem;
            padding-left: 1.5rem;
        }

        .post-content-body ul {
            list-style-type: square;
        }

        .post-content-body ol {
            list-style-type: decimal;
        }

        .post-content-body li {
            margin-bottom: 0.5rem;
        }

        .post-content-body blockquote {
            border-left: 4px solid var(--accent-primary);
            padding: 1rem 1.5rem;
            margin: 2.5rem 0;
            background: var(--bg-secondary);
            font-style: italic;
            color: var(--text-muted);
            border-radius: 0 6px 6px 0;
        }

        .post-content-body blockquote p {
            margin-bottom: 0;
        }

        .post-content-body a {
            color: var(--accent-primary);
            border-bottom: 1px dashed var(--accent-primary);
            transition: all 0.2s ease;
            font-weight: 600;
        }

        .post-content-body a:hover {
            color: var(--text-main);
            border-bottom-color: var(--text-main);
        }

        /* Responsive adjustments */
        @media (max-width: 992px) {
            .post-layout {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            .post-sidebar {
                position: static;
            }
        }

        /* Table inside blog post */
        .blog-table {
            width: 100%;
            border-collapse: collapse;
            margin: 2rem 0;
            font-size: 0.95rem;
        }

        .blog-table th {
            background-color: var(--bg-secondary);
            color: var(--text-main);
            font-family: var(--font-heading);
            font-weight: 700;
            text-transform: uppercase;
            border-bottom: 2px solid var(--border-color);
            padding: 12px;
            text-align: left;
        }

        .blog-table td {
            padding: 12px;
            border-bottom: 1px solid var(--border-color);
            color: var(--text-muted);
        }

        .blog-table tr:hover td {
            color: var(--text-main);
            background-color: rgba(255, 255, 255, 0.02);
        }

        /* Social sharing link styling */
        .share-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--bg-secondary);
            color: var(--text-muted);
            border: 1px solid var(--border-color);
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .share-btn:hover {
            color: var(--bg-primary);
            transform: translateY(-2px);
        }

        .share-btn.fb:hover { background: #1877F2; border-color: #1877F2; }
        .share-btn.tw:hover { background: #1DA1F2; border-color: #1DA1F2; }
        .share-btn.in:hover { background: #0077B5; border-color: #0077B5; }
        .share-btn.wa:hover { background: #25D366; border-color: #25D366; }

        /* Banner CTA Widget */
        .sidebar-cta {
            background: linear-gradient(135deg, var(--bg-secondary) 0%, rgba(21, 26, 32, 0.95) 100%);
            border: 1px solid var(--border-color);
            border-top: 4px solid var(--accent-primary);
        }

        .sidebar-cta.solar {
            border-top-color: var(--accent-solar);
        }

        .sidebar-cta.automacao {
            border-top-color: var(--accent-secondary);
        }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>

    <main style="padding-top: 80px;">
        <!-- ═══ BREADCRUMB VISUAL ═══ -->
        <nav class="breadcrumb-nav" style="background: var(--bg-secondary); border-bottom: 1px solid var(--border-color); padding: 1rem 0;">
            <div class="container" style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;">
                <a href="<%= getHomePrefix() %>/" style="color: inherit; text-decoration: none;">Home</a>
                <span style="margin: 0 0.5rem; color: var(--accent-primary);">/</span>
                <a href="<%= getHomePrefix() %>/blog" style="color: inherit; text-decoration: none;">Blog</a>
                <span style="margin: 0 0.5rem; color: var(--accent-primary);">/</span>
                <span style="color: var(--text-main);"><%= post.categoryLabel %></span>
            </div>
        </nav>

        <!-- ═══ HERO DO ARTIGO ═══ -->
        <section class="bg-blueprint" style="padding: 4rem 0; border-bottom: 1px solid var(--border-color);">
            <div class="container fade-in">
                <div style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-bottom: 1.5rem;">
                    <% 
                        let categoryColor = 'var(--accent-primary)';
                        if (post.category === 'solar') categoryColor = 'var(--accent-solar)';
                        if (post.category === 'automacao') categoryColor = 'var(--accent-secondary)';
                    %>
                    <span class="badge-mono" style="background: <%= categoryColor %>; color: var(--bg-primary); font-weight: bold; padding: 0.35rem 0.8rem; border-radius: 4px;">
                        <%= post.categoryLabel.toUpperCase() %>
                    </span>
                    <span style="font-family: var(--font-mono); color: var(--text-muted); font-size: 0.85rem;">
                        <i class="far fa-calendar-alt"></i> <%= post.date %>
                    </span>
                    <span style="font-family: var(--font-mono); color: var(--text-muted); font-size: 0.85rem;">
                        <i class="far fa-clock"></i> <%= post.readTime %> de leitura
                    </span>
                </div>

                <div class="grid grid-cols-2" style="gap: 4rem; align-items: center; grid-template-columns: 1.2fr 0.8fr;">
                    <div>
                        <h1 style="font-size: clamp(2rem, 3.5vw, 3.8rem); line-height: 1.1; margin-bottom: 1.5rem; text-transform: uppercase; font-family: var(--font-display);">
                            <%= post.title %>
                        </h1>
                        <p style="color: var(--text-muted); font-size: 1.15rem; line-height: 1.6; margin-bottom: 1rem;">
                            <%= post.summary %>
                        </p>
                        <div style="display: flex; align-items: center; gap: 12px; margin-top: 1.5rem;">
                            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--border-color); display: flex; align-items: center; justify-content: center; border: 1px solid var(--accent-primary);">
                                <i class="fas fa-user-cog" style="color: var(--accent-primary); font-size: 1.1rem;"></i>
                            </div>
                            <div>
                                <span style="display: block; font-size: 0.9rem; color: var(--text-main); font-weight: 600;"><%= post.author %></span>
                                <span style="display: block; font-size: 0.75rem; color: var(--text-muted); font-family: var(--font-mono); text-transform: uppercase;">Corpo Técnico Klyfe</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        <div style="width: 100%; border-radius: 8px; border: 1px solid var(--border-color); overflow: hidden; box-shadow: 0 10px 35px rgba(0,0,0,0.5);">
                            <img src="<%= post.heroImage %>" alt="<%= post.title %>" style="width: 100%; height: auto; display: block; filter: brightness(0.85) contrast(1.05);" loading="eager" width="500" height="320">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══ ÁREA DE LEITURA COM GRID ═══ -->
        <section class="section-padding" style="padding-top: 3rem; background: var(--bg-primary);">
            <div class="container">
                <div class="post-layout">
                    
                    <!-- Coluna Principal (Conteúdo) -->
                    <article class="post-main fade-in">
                        <div class="post-content-body">
                            <%- post.contentHtml %>
                        </div>
                    </article>

                    <!-- Coluna Lateral (Sidebar) -->
                    <aside class="post-sidebar fade-in">
                        
                        <!-- Sumário Dinâmico (TOC) -->
                        <div class="toc-container bracket-box" style="margin-bottom: 2rem; background: var(--bg-secondary); padding: 1.5rem;">
                            <h4 style="font-family: var(--font-heading); color: var(--accent-primary); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                                SUMÁRIO
                            </h4>
                            <ul id="toc-list" style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.75rem;">
                                <!-- Gerado dinamicamente via JS client-side -->
                            </ul>
                        </div>

                        <!-- Redes Sociais / Compartilhamento -->
                        <div class="bracket-box" style="margin-bottom: 2rem; background: var(--bg-secondary); padding: 1.5rem; text-align: center;">
                            <h4 style="font-family: var(--font-heading); color: var(--text-main); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 1px;">
                                COMPARTILHAR
                            </h4>
                            <div style="display: flex; justify-content: center; gap: 0.75rem;">
                                <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(canonical) %>" target="_blank" rel="noopener" class="share-btn fb" aria-label="Compartilhar no Facebook">
                                    <i class="fab fa-facebook-f"></i>
                                </a>
                                <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(canonical) %>&text=<%= encodeURIComponent(post.title) %>" target="_blank" rel="noopener" class="share-btn tw" aria-label="Compartilhar no X (Twitter)">
                                    <i class="fab fa-twitter"></i>
                                </a>
                                <a href="https://www.linkedin.com/shareArticle?mini=true&url=<%= encodeURIComponent(canonical) %>&title=<%= encodeURIComponent(post.title) %>" target="_blank" rel="noopener" class="share-btn in" aria-label="Compartilhar no LinkedIn">
                                    <i class="fab fa-linkedin-in"></i>
                                </a>
                                <a href="https://api.whatsapp.com/send?text=<%= encodeURIComponent(post.title + ' - ' + canonical) %>" target="_blank" rel="noopener" class="share-btn wa" aria-label="Compartilhar no WhatsApp">
                                    <i class="fab fa-whatsapp"></i>
                                </a>
                            </div>
                        </div>

                        <!-- CTA Rápido / Lateral de Captação -->
                        <div class="bracket-box sidebar-cta <%= post.category %>" style="padding: 2rem; border-radius: 6px; text-align: center;">
                            <h3 style="font-size: 1.4rem; margin-bottom: 1rem; line-height: 1.3;">
                                Quer economizar ou automatizar <%= cityData.preposition %> <%= cityData.name %>?
                            </h3>
                            <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; margin-bottom: 1.5rem;">
                                Converse com a nossa engenharia e receba uma análise estrutural ou simulação gratuita em ambiente BIM.
                            </p>
                            <a href="https://wa.me/5583991330972?text=<%= encodeURIComponent(cityData.whatsappMessage || 'Olá! Gostaria de um orçamento.') %>" target="_blank" rel="noopener" class="btn btn-primary" style="width: 100%; justify-content: center;">
                                <i class="fab fa-whatsapp"></i> Falar Conosco
                            </a>
                        </div>

                    </aside>
                </div>
            </div>
        </section>

        <!-- ═══ LINK CRUZADO GEO-SEO ═══ -->
        <% if (cityKey !== 'default') { %>
            <section style="padding: 2rem 0; background: var(--bg-secondary); border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
                <div class="container" style="text-align: center;">
                    <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 0;">
                        Este artigo também possui dados específicos para a região de 
                        <a href="<%= alternateUrl %>" style="color: var(--accent-primary); text-decoration: none; font-weight: 600; border-bottom: 1px solid transparent; transition: 0.3s;" onmouseover="this.style.borderBottomColor='var(--accent-primary)'" onmouseout="this.style.borderBottomColor='transparent'">
                            <%= alternateCityName %>
                        </a>.
                    </p>
                </div>
            </section>
        <% } %>

        <!-- ═══ FAQ DO ARTIGO ═══ -->
        <% if (post.faq && post.faq.length > 0) { %>
            <section class="section-padding" style="background: var(--bg-secondary); border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
                <div class="container" style="max-width: 800px;">
                    <div class="section-separator fade-in" style="justify-content: center;"><%- include('partials/symbol') %> <span>FAQ TÉCNICO</span></div>
                    <h2 style="text-align: center; margin-bottom: 4rem;">Dúvidas Frequentes sobre o Assunto</h2>
                    
                    <div class="faq-accordion fade-in">
                        <% post.faq.forEach(item => { %>
                            <div class="faq-item" style="border-bottom: 1px solid var(--border-color); padding: 1.5rem 0;">
                                <button class="faq-question" style="width: 100%; display: flex; justify-content: space-between; align-items: center; background: none; border: none; color: var(--text-main); font-size: 1.1rem; font-weight: 600; text-align: left; cursor: pointer;">
                                    <%= item.question %>
                                    <i class="fas fa-plus" style="font-size: 0.8rem; color: var(--accent-primary);"></i>
                                </button>
                                <div class="faq-answer" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out;">
                                    <p style="padding-top: 1rem; color: var(--text-muted); line-height: 1.6;"><%= item.answer %></p>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- ═══ LEITURAS RECOMENDADAS (Artigos Recomendados) ═══ -->
        <% if (locals.recommendedPosts && recommendedPosts.length > 0) { %>
            <section class="section-padding" style="background: var(--bg-primary);">
                <div class="container">
                    <div class="section-separator fade-in" style="justify-content: center;"><%- include('partials/symbol') %> <span>CONHECIMENTO ADICIONAL</span></div>
                    <h2 style="text-align: center; margin-bottom: 4rem;">Artigos Recomendados para Você</h2>
                    
                    <div class="grid grid-cols-3">
                        <% recommendedPosts.forEach(recPost => { %>
                            <% 
                                let recColor = 'var(--accent-primary)';
                                if (recPost.category === 'solar') recColor = 'var(--accent-solar)';
                                if (recPost.category === 'automacao') recColor = 'var(--accent-secondary)';
                            %>
                            <div class="bracket-box fade-in" style="display: flex; flex-direction: column;">
                                <span class="badge-mono" style="background: <%= recColor %>; color: var(--bg-primary); margin-bottom: 1rem; align-self: flex-start; font-weight: bold;">
                                    <%= recPost.categoryLabel %> | <%= recPost.readTime %>
                                </span>
                                <h3 style="color: var(--text-main); margin-bottom: 1rem; flex-grow: 1; font-size: 1.35rem; line-height: 1.3;">
                                    <%= recPost.title %>
                                </h3>
                                <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; line-height: 1.5;">
                                    <%= recPost.summary %>
                                </p>
                                <a href="<%= getHomePrefix() %>/blog/<%= recPost.slug %>" style="color: <%= recColor %>; font-family: var(--font-heading); text-transform: uppercase; font-weight: bold; font-size: 0.9rem;">
                                    Ler artigo →
                                </a>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- ═══ CTA PRINCIPAL / RODAPÉ DO ARTIGO ═══ -->
        <section class="section-padding" style="background: linear-gradient(rgba(10,13,16,0.92), rgba(10,13,16,0.92)), url('/img/hero-klyfe.webp') center/cover; border-top: 1px solid var(--border-color);">
            <div class="container" style="text-align: center;">
                <div class="section-separator" style="justify-content: center;"><%- include('partials/symbol') %> <span>DÚVIDAS TÉCNICAS?</span></div>
                <h2 style="margin-bottom: 2rem;">Desenvolva sua Estrutura <%= cityData.preposition %> <%= cityData.name %><br>com <span style="color:var(--accent-primary)">Engenheiros de Elite.</span></h2>
                <p style="color: var(--text-muted); max-width: 700px; margin: 0 auto 3rem auto;">
                    Na Klyfe Electric, aplicamos modelagem BIM 3D, cumprimento estrito das normas da ABNT/Energisa e emissão de ART para garantir máxima proteção e eficiência nas suas instalações.
                </p>
                <a href="https://wa.me/5583991330972?text=<%= encodeURIComponent(cityData.whatsappMessage || 'Olá! Gostaria de um orçamento.') %>" class="btn btn-primary" style="padding: 1.2rem 2.5rem; font-size: 1.1rem;">
                    <i class="fab fa-whatsapp"></i> Falar com Engenheiro no WhatsApp
                </a>
            </div>
        </section>

    </main>

    <%- include('partials/whatsapp') %>
    <%- include('partials/footer') %>
    
    <script>
        // Table of Contents generator
        document.addEventListener("DOMContentLoaded", function() {
            const postBody = document.querySelector(".post-content-body");
            const tocList = document.getElementById("toc-list");
            if (postBody && tocList) {
                const headings = postBody.querySelectorAll("h2");
                if (headings.length === 0) {
                    const tocContainer = document.querySelector(".toc-container");
                    if (tocContainer) tocContainer.style.display = "none";
                }
                headings.forEach((heading, index) => {
                    const id = "heading-" + index;
                    heading.setAttribute("id", id);
                    
                    const li = document.createElement("li");
                    const a = document.createElement("a");
                    a.setAttribute("href", "#" + id);
                    a.textContent = heading.textContent;
                    a.style.color = "var(--text-muted)";
                    a.style.fontSize = "0.85rem";
                    a.style.lineHeight = "1.3";
                    a.style.textDecoration = "none";
                    a.style.display = "block";
                    a.style.transition = "color 0.2s";
                    
                    a.addEventListener("mouseover", () => a.style.color = "var(--accent-primary)");
                    a.addEventListener("mouseout", () => a.style.color = "var(--text-muted)");
                    
                    li.appendChild(a);
                    tocList.appendChild(li);
                });
            }
        });
    </script>
    <script src="/js/main.js"></script>
</body>
</html>
