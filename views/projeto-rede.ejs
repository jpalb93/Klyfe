<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main>
        <!-- ProjetoRedePage -->

        <!-- ═══ BREADCRUMB VISUAL ═══ -->
        <nav class="breadcrumb-nav" style="background: var(--bg-secondary); border-bottom: 1px solid var(--border-color); padding: 1rem 0;">
            <div class="container" style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;">
                <a href="/" style="color: inherit; text-decoration: none;">Home</a>
                <span style="margin: 0 0.5rem; color: var(--accent-primary);">/</span>
                <a href="/solucoes" style="color: inherit; text-decoration: none;">Soluções</a>
                <span style="margin: 0 0.5rem; color: var(--accent-primary);">/</span>
                <a href="/solucoes/eletrica" style="color: inherit; text-decoration: none;">Serviços Elétricos</a>
                <span style="margin: 0 0.5rem; color: var(--accent-primary);">/</span>
                <span style="color: var(--text-main);">Projeto de Rede</span>
            </div>
        </nav>

        <!-- ═══ HERO ═══ -->
        <section class="hero-internal bg-blueprint" style="padding: 6rem 0;">
            <div class="container fade-in">
                <div class="section-separator"><%- include('partials/symbol') %> <span>INFRAESTRUTURA DE DADOS</span></div>
                <h1 style="font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1.1; margin-top: 1.5rem; font-weight: 800;">
                    Projeto de Rede, Telefonia <br>
                    <span class="text-gradient">e Antena Coletiva.</span>
                </h1>
                <p style="color: var(--text-muted); font-size: 1.25rem; max-width: 800px; margin: 2rem 0; line-height: 1.6;">
                    Conectividade de alta performance para residências, condomínios e empresas. Projetos de cabeamento estruturado e sistemas de comunicação com certificação e ART.
                </p>
                <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                    <a href="https://wa.me/5583991330972" class="btn btn-primary">Solicitar Orçamento</a>
                    <a href="#detalhes" class="btn btn-ghost">Especificações Técnicas →</a>
                </div>
            </div>
        </section>

        <!-- ═══ SNAPSHOT DE VALOR ═══ -->
        <section style="padding: 4rem 0; background: var(--bg-primary); border-bottom: 1px solid var(--border-color);">
            <div class="container">
                <div class="grid grid-cols-4">
                    <div class="feature-card-simple">
                        <div class="icon-wrap"><i class="fas fa-network-wired"></i></div>
                        <h4>Rede Estruturada</h4>
                        <p>Organização total de racks, switches e pontos de dados.</p>
                    </div>
                    <div class="feature-card-simple">
                        <div class="icon-wrap"><i class="fas fa-wifi"></i></div>
                        <h4>Wi-Fi de Alta Performance</h4>
                        <p>Mapeamento de sinal para eliminar zonas mortas (dead zones).</p>
                    </div>
                    <div class="feature-card-simple">
                        <div class="icon-wrap"><i class="fas fa-phone-alt"></i></div>
                        <h4>Telefonia & VoIP</h4>
                        <p>Sistemas de PABX e interfonia inteligente para condomínios.</p>
                    </div>
                    <div class="feature-card-simple">
                        <div class="icon-wrap"><i class="fas fa-satellite-dish"></i></div>
                        <h4>Antena Digital</h4>
                        <p>Distribuição de sinal de TV com qualidade 4K em todos os pontos.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══ DETALHES / ESCOPO ═══ -->
        <section id="detalhes" class="section-padding">
            <div class="container">
                <div class="grid grid-cols-2 gap-xl align-center">
                    <div class="bracket-box">
                        <h3 style="margin-bottom: 1.5rem; font-family: var(--font-mono); color: var(--accent-primary);">// ESCOPO TÉCNICO</h3>
                        <div class="spec-item"><strong>Cabeamento CAT6/CAT6A:</strong> Máxima velocidade de tráfego de dados.</div>
                        <div class="spec-item"><strong>Fibra Óptica:</strong> Conexões de backbone para longas distâncias.</div>
                        <div class="spec-item"><strong>Certificação de Pontos:</strong> Testes de performance em cada conexão.</div>
                        <div class="spec-item"><strong>Identificação:</strong> Documentação e anilhamento de todos os cabos.</div>
                    </div>
                    <div>
                        <h2 style="margin-bottom: 2rem;">Conectividade que não <em class="text-gradient">te deixa na mão.</em></h2>
                        <p style="color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.7;">
                            Em um mundo hiperconectado, a rede é o sistema nervoso da sua casa ou empresa. Um projeto técnico evita lentidão em chamadas de vídeo, quedas no streaming e garante que sua automação funcione sem interrupções.
                        </p>
                        <ul class="checklist-modern">
                            <li>Dimensionamento de Racks e Servidores</li>
                            <li>Projeto de Wi-Fi Mesh e Access Points</li>
                            <li>Interfonia Digital e VoIP para Condomínios</li>
                            <li>Infraestrutura para CFTV e Segurança</li>
                            <li>Anotação de Responsabilidade Técnica (ART)</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══ FAQ ACCORDION ═══ -->
        <section class="section-padding" style="background: var(--bg-secondary);">
            <div class="container" style="max-width: 900px;">
                <h2 style="text-align: center; margin-bottom: 3rem;">Dúvidas Frequentes sobre <br><span class="text-gradient">Infraestrutura de Rede</span></h2>
                
                <div class="faq-accordion">
                    <div class="faq-item active">
                        <div class="faq-question">Qual a diferença entre CAT5e e CAT6? <i class="fas fa-plus"></i></div>
                        <div class="faq-answer">
                            <div class="faq-answer-inner">
                                O CAT6 possui maior largura de banda e suporta velocidades de até 10Gbps em distâncias curtas, além de ter menos interferência. É o padrão recomendado para novas instalações que buscam durabilidade tecnológica.
                            </div>
                        </div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question">Por que o Wi-Fi da minha casa é lento em alguns cômodos? <i class="fas fa-plus"></i></div>
                        <div class="faq-answer">
                            <div class="faq-answer-inner">
                                Isso ocorre devido a barreiras físicas (paredes) e interferências. Um projeto de rede posiciona estrategicamente Access Points cabeados para garantir sinal estável em 100% da área, sem perdas de velocidade.
                            </div>
                        </div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question">Vocês fazem apenas o projeto ou a instalação também? <i class="fas fa-plus"></i></div>
                        <div class="faq-answer">
                            <div class="faq-answer-inner">
                                Realizamos ambos. Entregamos o projeto técnico detalhado e possuímos equipe própria para a passagem de cabos, montagem de racks e configuração dos equipamentos.
                            </div>
                        </div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question">É possível unificar internet, telefone e TV no mesmo projeto? <i class="fas fa-plus"></i></div>
                        <div class="faq-answer">
                            <div class="faq-answer-inner">
                                Sim. O conceito de cabeamento estruturado permite gerenciar todos os sistemas de comunicação de forma centralizada e organizada, facilitando manutenções futuras.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══ LINKS RELACIONADOS ═══ -->
        <section style="padding: 4rem 0; border-top: 1px solid var(--border-color);">
            <div class="container">
                <h3 style="margin-bottom: 2rem; font-family: var(--font-mono); font-size: 0.8rem; letter-spacing: 2px;">// SOLUÇÕES RELACIONADAS</h3>
                <div class="grid grid-cols-4">
                    <a href="<%= getHomePrefix() %>/solucoes/automacao/automacao-residencial" class="related-card">
                        <h4>Automação</h4>
                        <span>Ver solução →</span>
                    </a>
                    <a href="<%= getHomePrefix() %>/solucoes/eletrica" class="related-card">
                        <h4>Serviços Elétricos</h4>
                        <span>Ver solução →</span>
                    </a>
                    <a href="<%= getHomePrefix() %>/solucoes/engenharia/projeto-eletrico" class="related-card">
                        <h4>Projeto Elétrico</h4>
                        <span>Ver solução →</span>
                    </a>
                    <a href="<%= getHomePrefix() %>/solucoes/engenharia/laudos-eletricos" class="related-card">
                        <h4>Laudos Técnicos</h4>
                        <span>Ver solução →</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- ═══ CTA FINAL ═══ -->
        <section class="cta-banner" style="margin: 4rem 0;">
            <div class="container fade-in" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 2rem;">
                <div>
                    <h2 style="color: var(--bg-primary);">Sua rede está pronta para o futuro?</h2>
                    <p style="color: rgba(255,255,255,0.8);">Conectividade total e organizada para sua casa ou empresa.</p>
                </div>
                <a href="https://wa.me/5583991330972" class="btn btn-dark">Solicitar Orçamento de Projeto</a>
            </div>
        </section>

    </main>

    <%- include('partials/whatsapp') %>
    <%- include('partials/footer') %>

    <!-- Schema.org FAQPage JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Qual a diferença entre CAT5e e CAT6?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "O CAT6 possui maior largura de banda e suporta velocidades de até 10Gbps em distâncias curtas, além de ter menos interferência. É o padrão recomendado para novas instalações que buscam durabilidade tecnológica."
          }
        },
        {
          "@type": "Question",
          "name": "Por que o Wi-Fi da minha casa é lento em alguns cômodos?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Isso ocorre devido a barreiras físicas (paredes) e interferências. Um projeto de rede posiciona estrategicamente Access Points cabeados para garantir sinal estável em 100% da área, sem perdas de velocidade."
          }
        },
        {
          "@type": "Question",
          "name": "Vocês fazem apenas o projeto ou a instalação também?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Realizamos ambos. Entregamos o projeto técnico detalhado e possuímos equipe própria para a passagem de cabos, montagem de racks e configuração dos equipamentos."
          }
        },
        {
          "@type": "Question",
          "name": "É possível unificar internet, telefone e TV no mesmo projeto?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sim. O conceito de cabeamento estruturado permite gerenciar todos os sistemas de comunicação de forma centralizada e organizada, facilitando manutenções futuras."
          }
        }<% if (typeof cityData !== 'undefined' && cityData.faqExtra) { %>,
        {
          "@type": "Question",
          "name": "<%= cityData.faqExtra.question.replace(/"/g, '\\"') %>",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<%= cityData.faqExtra.answer.replace(/"/g, '\\"') %>"
          }
        }<% } %>
      ]
    }
    </script>

    <script src="/js/main.js"></script>
</body>
</html>
