<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head') %>
    <style>
        .form-group { margin-bottom: 1.5rem; }
        .form-control {
            width: 100%;
            padding: 1rem;
            background-color: var(--bg-primary);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            font-family: var(--font-body);
        }
        .form-control:focus {
            outline: none;
            border-color: var(--accent-primary);
        }
        label {
            display: block;
            margin-bottom: 0.5rem;
            font-family: var(--font-heading);
            color: var(--text-muted);
            text-transform: uppercase;
            font-size: 0.9rem;
        }
        .contact-info p {
            margin-bottom: 1rem;
            display: flex;
            align-items: flex-start;
            gap: 1rem;
        }
        .contact-info i {
            color: var(--accent-primary);
            font-size: 1.2rem;
            margin-top: 0.2rem;
        }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>

    <main style="padding-top: 80px;">
        <section class="bg-blueprint" style="padding: 4rem 0; border-bottom: 1px solid var(--border-color);">
            <div class="container fade-in">
                <div style="font-family: var(--font-mono); color: var(--text-muted); margin-bottom: 1rem; font-size: 0.9rem;">
                    Home > Contato
                </div>
                <h1>FALE COM A KLYFE ELECTRIC</h1>
                <p style="color: var(--text-muted); font-size: 1.2rem; max-width: 600px; margin-top: 1rem;">
                    Atendemos Campina Grande, João Pessoa e toda a região. Orçamento sem compromisso.
                </p>
            </div>
        </section>

        <!-- Formulário e Info -->
        <section class="section-padding">
            <div class="container grid grid-cols-2" style="gap: 4rem;">
                <!-- ESQUERDA: Formulário -->
                <div class="fade-in">
                    <form id="contact-form" class="bracket-box" style="padding: 3rem;">
                        <div class="form-group">
                            <label for="nome">Nome completo *</label>
                            <input type="text" id="nome" name="nome" class="form-control" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="email">E-mail *</label>
                            <input type="email" id="email" name="email" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label for="telefone">Telefone / WhatsApp *</label>
                            <input type="tel" id="telefone" name="telefone" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label for="cidade">Cidade *</label>
                            <input type="text" id="cidade" name="cidade" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label for="servico">Serviço de interesse:</label>
                            <select id="servico" name="servico" class="form-control" required style="appearance: none;">
                                <option value="">Selecione uma opção...</option>
                                <option value="Soluções Elétricas">Soluções Elétricas</option>
                                <option value="Automação">Automação</option>
                                <option value="Energia Solar">Energia Solar</option>
                                <option value="Manutenção">Manutenção</option>
                                <option value="Outro">Outro</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="mensagem">Descreva seu projeto</label>
                            <textarea id="mensagem" name="mensagem" class="form-control" rows="4"></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary" style="width: 100%;">ENVIAR SOLICITAÇÃO</button>
                    </form>
                </div>

                <!-- DIREITA: Informações e Mapa -->
                <div class="fade-in">
                    <div class="contact-info" style="margin-bottom: 3rem;">
                        <p><i class="fas fa-map-marker-alt"></i> <span>R. da Cerâmica, 34 - Santa Rosa<br>Campina Grande - PB, CEP 58416-480</span></p>
                        <p><i class="fas fa-phone"></i> <span>(83) 99133-0972</span></p>
                        <p><i class="fab fa-whatsapp"></i> <a href="https://wa.me/5583991330972" target="_blank" rel="noopener" style="color: var(--accent-secondary)">wa.me/5583991330972</a></p>
                        <p><i class="fas fa-envelope"></i> <span>contato@klyfeelectric.com.br</span></p>
                        <p><i class="fas fa-clock"></i> <span>Seg–Sex: 08h–18h | Sáb: 08h–12h</span></p>
                        <p><i class="fas fa-star" style="color: var(--accent-primary)"></i> <span style="font-weight: bold; color: var(--accent-primary)">5,0 — 120 avaliações no Google</span></p>
                    </div>

                    <!-- Chips Atendimento -->
                    <div style="margin-bottom: 2rem;">
                        <h4 style="font-family: var(--font-heading); color: var(--text-muted); margin-bottom: 1rem; text-transform: uppercase;">Nossa área de atuação:</h4>
                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                            <span class="badge-mono">[Campina Grande]</span>
                            <span class="badge-mono">[João Pessoa]</span>
                            <span class="badge-mono">[Patos]</span>
                            <span class="badge-mono">[Lagoa Seca]</span>
                            <span class="badge-mono">[Queimadas]</span>
                            <span class="badge-mono">[Boa Vista]</span>
                            <span class="badge-mono">[Caruaru]</span>
                            <span class="badge-mono">[e toda a Paraíba]</span>
                        </div>
                    </div>

                    <!-- Mapa Fallback Estilizado -->
                    <div class="bracket-box" style="background-color: var(--bg-primary); text-align: center; padding: 3rem 1rem;">
                        <i class="fas fa-map" style="font-size: 3rem; color: var(--border-color); margin-bottom: 1rem;"></i>
                        <h3 style="margin-bottom: 1rem;">Klyfe Electric (Sede)</h3>
                        <a href="https://maps.google.com/?q=R.+da+Ceramica,+34+-+Santa+Rosa,+Campina+Grande+-+PB" target="_blank" rel="noopener" class="btn btn-outline" style="font-size: 0.9rem;">Ver no Google Maps →</a>
                    </div>

                </div>
            </div>
        </section>

    </main>

    <%- include('partials/whatsapp') %>
    <%- include('partials/footer') %>
    <script src="/js/main.js"></script>
</body>
</html>
