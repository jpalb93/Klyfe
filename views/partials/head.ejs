<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<meta name="description" content="<%= description %>">
<link rel="canonical" href="<%= canonical %>">
<meta name="robots" content="<%= locals.robots || 'index, follow' %>">
<meta name="google-site-verification" content="VN7ObKFVGeA9nxcdp6P2VYnHDmbp5iKerV289RTjdrc" />

<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="manifest" href="/site.webmanifest">
<link rel="shortcut icon" href="/favicon.ico">

<!-- Open Graph -->
<meta property="og:title" content="<%= title %>">
<meta property="og:description" content="<%= description %>">
<meta property="og:type" content="website">
<meta property="og:locale" content="pt_BR">
<meta property="og:url" content="<%= canonical %>">
<meta property="og:image" content="https://www.klyfeelectric.com.br/img/logo-klyfe.webp">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:site_name" content="Klyfe Electric">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= title %>">
<meta name="twitter:description" content="<%= description %>">
<meta name="twitter:image" content="https://www.klyfeelectric.com.br/img/logo-klyfe.webp">
<meta name="twitter:site" content="@klyfeelectric">
<meta name="twitter:creator" content="@klyfeelectric">

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Bebas+Neue&family=IBM+Plex+Mono&family=IBM+Plex+Sans:wght@400;600&display=swap" rel="stylesheet">

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!-- CSS Global -->
<link rel="stylesheet" href="/css/style.css">

<!-- Schema.org JSON-LD -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "Klyfe Electric",
      "image": "https://www.klyfeelectric.com.br/img/hero-klyfe.webp",
      "logo": "https://www.klyfeelectric.com.br/img/Assinatura%20Completa%20-%20AmareloB%20-%20Klyfe.webp",
      "description": "Empresa de engenharia elétrica, automação e energia solar fotovoltaica <%= cityData.preposition %> <%= cityData.name %> e região.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "<%= cityData.address %>",
        "addressLocality": "<%= cityData.name %>",
        "addressRegion": "PB",
        "addressCountry": "BR"
      },
      "telephone": "+5583991330972",
      "url": "https://www.klyfeelectric.com.br",
      "sameAs": [
        "https://www.linkedin.com/company/klyfeelectric",
        "https://www.instagram.com/klyfeelectric"
      ],
      "areaServed": ["<%= cityData.name %>", "Paraíba"],
      "serviceType": ["Instalação Elétrica", "Automação", "Energia Solar"]
    }
  ]
}
</script>
<% if (locals.jsonLd) { %>
    <%- jsonLd %>
<% } %>
