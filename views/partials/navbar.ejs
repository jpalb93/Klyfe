<% 
  let currentCityDisplay = 'Paraíba';
  let activeCityKey = 'default';
  if (typeof cityKey !== 'undefined') {
      activeCityKey = cityKey;
      if (cityKey === 'campina-grande') currentCityDisplay = 'Campina Grande';
      else if (cityKey === 'joao-pessoa') currentCityDisplay = 'João Pessoa';
  }

  let cityPrefix = (activeCityKey !== 'default') ? '/' + activeCityKey : '';
  let currentPage = (typeof page !== 'undefined') ? page : '';
  let servicePath = (['engenharia', 'eletrica', 'automacao', 'solar'].includes(currentPage)) ? `/solucoes/${currentPage}` : '/solucoes';

  const waMenuMsg = (typeof cityData !== 'undefined' && cityData.whatsappMessage) ? cityData.whatsappMessage : 'Olá! Gostaria de solicitar um orçamento.';
  const waMenuUrl = `https://wa.me/5583991330972?text=${encodeURIComponent(waMenuMsg)}`;

  // Filtro de Serviços Disponíveis
  const isAllEnabled = (typeof cityData !== 'undefined' && cityData.allServices === true);
  const availableServices = (typeof cityData !== 'undefined' && cityData.services) ? Object.keys(cityData.services) : [];
  
  const isServiceEnabled = (serviceKey) => isAllEnabled || availableServices.includes(serviceKey);
%>





<nav class="navbar">
    <div class="container">
        <a href="<%= (activeCityKey !== 'default') ? '/' + activeCityKey : '/' %>" class="logo logo-animated" aria-label="Klyfe Electric - Voltar para a Home">
            <span class="sr-only" style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0;">Klyfe Electric</span>
            <%- include('logo') %>
        </a>
        <div class="nav-links">
            <a href="<%= (activeCityKey !== 'default') ? '/' + activeCityKey : '/' %>" class="<%= currentPage === 'home' ? 'active' : '' %>">Home</a>
            <div class="dropdown">
                <a href="<%= cityPrefix %>/solucoes" class="<%= (currentPage.includes('solucoes') || currentPage.includes('eletrica') || currentPage.includes('engenharia') || currentPage.includes('automacao') || currentPage.includes('solar')) ? 'active' : '' %>">Soluções <i class="fas fa-chevron-down" style="font-size:0.7rem"></i></a>

                <div class="dropdown-menu">
                    <% if (isServiceEnabled('engenharia')) { %>
                        <a href="<%= cityPrefix %>/solucoes/engenharia"><i class="fas fa-hard-hat" style="color:var(--text-muted);margin-right:0.5rem"></i> Engenharia Elétrica</a>
                    <% } %>
                    <% if (isServiceEnabled('eletrica')) { %>
                        <a href="<%= cityPrefix %>/solucoes/eletrica"><i class="fas fa-bolt" style="color:var(--accent-primary);margin-right:0.5rem"></i> Serviços Elétricos</a>
                    <% } %>
                    <% if (isServiceEnabled('automacao')) { %>
                        <a href="<%= cityPrefix %>/solucoes/automacao"><i class="fas fa-cog" style="color:var(--accent-secondary);margin-right:0.5rem"></i> Automação</a>
                    <% } %>
                    <% if (isServiceEnabled('solar')) { %>
                        <a href="<%= cityPrefix %>/solucoes/solar"><i class="fas fa-sun" style="color:var(--accent-solar);margin-right:0.5rem"></i> Energia Solar</a>
                    <% } %>
                </div>


            </div>
            <a href="<%= cityPrefix %>/quem-somos" class="<%= currentPage === 'quem-somos' ? 'active' : '' %>">Quem Somos</a>
            <a href="<%= cityPrefix %>/projetos" class="<%= currentPage === 'projetos' ? 'active' : '' %>">Projetos</a>
            <a href="<%= cityPrefix %>/blog" class="<%= currentPage === 'blog' ? 'active' : '' %>">Blog</a>

            <a href="<%= cityPrefix %>/contato" class="btn-contact">Contato</a>
            
            <div class="dropdown location-selector">
                <a href="#" class="nav-location" aria-label="Selecionar região de atendimento - Cidade atual: <%= currentCityDisplay %>">
                    <i class="fas fa-map-marker-alt"></i> 
                    <span><%= currentCityDisplay %></span>
                    <i class="fas fa-chevron-down" style="font-size:0.6rem; margin-left:0.3rem"></i>
                </a>
                <div class="dropdown-menu">
                    <div style="padding: 0.5rem 1.2rem; font-size: 0.7rem; color: var(--accent-primary); text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid var(--border-color);">Região de Atendimento</div>
                    <a href="<%= servicePath %>">Estado da Paraíba</a>
                    <a href="/campina-grande<%= servicePath %>">Campina Grande</a>
                    <a href="/joao-pessoa<%= servicePath %>">João Pessoa</a>
                </div>
            </div>

            <a href="/contato" class="btn btn-primary" style="padding:0.7rem 1.5rem;margin-left:0.5rem;">Solicitar Orçamento</a>

        </div>
        <div class="nav-mobile-actions">
            <div class="mobile-location-tag" onclick="document.querySelector('.quick-city-selector').classList.toggle('open')">
                <i class="fas fa-map-marker-alt"></i>
                <span><%= (activeCityKey === 'default') ? 'PB' : (activeCityKey === 'campina-grande' ? 'CG' : 'JP') %></span>
            </div>
            <button class="hamburger" aria-label="Menu"><i class="fas fa-bars"></i></button>
        </div>
    </div>
    
    <!-- Seletor Rápido de Cidade (Mobile) -->
    <div class="quick-city-selector">
        <div class="quick-city-header">Selecione sua Região</div>
        <a href="<%= servicePath %>" class="<%= activeCityKey === 'default' ? 'active' : '' %>">
            <i class="fas fa-map"></i> Paraíba (Geral)
        </a>
        <a href="/campina-grande<%= servicePath %>" class="<%= activeCityKey === 'campina-grande' ? 'active' : '' %>">
            <i class="fas fa-map-marker-alt"></i> Campina Grande
        </a>
        <a href="/joao-pessoa<%= servicePath %>" class="<%= activeCityKey === 'joao-pessoa' ? 'active' : '' %>">
            <i class="fas fa-map-marker-alt"></i> João Pessoa
        </a>
    </div>
</nav>

<!-- Mobile Nav -->
<div class="mobile-overlay"></div>
<div class="mobile-nav">
    <button class="close-btn" aria-label="Fechar menu"><i class="fas fa-times"></i></button>
    <div class="logo-mobile-wrapper">
        <%- include('logo') %>
    </div>
    <a href="<%= cityPrefix || '/' %>">Home</a>
    
    <% if (isServiceEnabled('engenharia')) { %>
        <a href="<%= cityPrefix %>/solucoes/engenharia">Engenharia Elétrica</a>
    <% } %>
    <% if (isServiceEnabled('eletrica')) { %>
        <a href="<%= cityPrefix %>/solucoes/eletrica">Serviços Elétricos</a>
    <% } %>
    <% if (isServiceEnabled('automacao')) { %>
        <a href="<%= cityPrefix %>/solucoes/automacao">Automação</a>
    <% } %>
    <% if (isServiceEnabled('solar')) { %>
        <a href="<%= cityPrefix %>/solucoes/solar">Energia Solar</a>
    <% } %>


    <a href="<%= cityPrefix %>/quem-somos">Quem Somos</a>
    <a href="<%= cityPrefix %>/projetos">Projetos</a>
    <a href="<%= cityPrefix %>/blog">Blog</a>
    <a href="<%= cityPrefix %>/contato">Contato</a>


    <!-- Seletor de Região Mobile -->
    <div class="mobile-location-selector">
        <p>Selecione sua Região:</p>
        <div class="mobile-location-links">
            <a href="<%= servicePath %>" class="<%= activeCityKey === 'default' ? 'active' : '' %>">
                <i class="fas fa-map"></i> Paraíba (Geral)
            </a>
            <a href="/campina-grande<%= servicePath %>" class="<%= activeCityKey === 'campina-grande' ? 'active' : '' %>">
                <i class="fas fa-map-marker-alt"></i> Campina Grande
            </a>
            <a href="/joao-pessoa<%= servicePath %>" class="<%= activeCityKey === 'joao-pessoa' ? 'active' : '' %>">
                <i class="fas fa-map-marker-alt"></i> João Pessoa
            </a>
        </div>
    </div>

    <a href="<%= waMenuUrl %>" target="_blank" rel="noopener" style="color:var(--accent-secondary);margin-top:1.5rem;border-bottom:none"><i class="fab fa-whatsapp"></i> (83) 99133-0972</a>

</div>

