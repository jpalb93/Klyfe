            <div class="container fade-in" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 2rem;">
                <div>
                    <h2 style="color: var(--bg-primary);">Transforme sua casa na melhor <br>experiência de morar.</h2>
                    <p style="color: rgba(255,255,255,0.8);">Tecnologia, conforto e sofisticação para sua família.</p>
                </div>
                <a href="https://wa.me/5583991330972" class="btn btn-dark">Solicitar Orçamento de Smart Home</a>
            </div>
        </section>

    </main>

    <%- include('partials/whatsapp') %>
