<!DOCTYPE html>
<html lang="pt-BR">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>
<main>
    <% const cityPrefix = getHomePrefix(); %>
    
    <!-- HERO -->
    <section class="page-hero bg-blueprint" style="padding-top:120px;padding-bottom:4rem">
        <div class="container fade-in">
        <!-- ═══ BREADCRUMB VISUAL ═══ -->
        <nav class="breadcrumb-nav" style="background: var(--bg-secondary); border-bottom: 1px solid var(--border-color); padding: 1rem 0;">
            <div class="container" style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;">
                <a href="<%= getHomePrefix() || '/' %>" style="color: inherit; text-decoration: none;">Home</a>
                <span style="margin: 0 0.5rem; color: var(--accent-primary);">/</span>
                <a href="<%= getHomePrefix() %>/solucoes" style="color: inherit; text-decoration: none;">Soluções</a>
                <span style="margin: 0 0.5rem; color: var(--accent-primary);">/</span>
                <span style="color: var(--text-main);">Engenharia Elétrica <%= cityData.preposition %> <%= cityData.name %></span>
            </div>
        </nav>
        <div class="container fade-in">
            <div class="section-separator fade-in"><%- include('partials/symbol') %> <span>ENGENHARIA DE PRECISÃO</span></div>
            <h1 style="color:var(--text-main); font-size: 3.5rem; line-height: 1.1; margin-top: 1.5rem;">Engenharia Elétrica <%= cityData.preposition %><br><span style="color:var(--accent-primary)"><%= cityData.name %> e Região.</span></h1>
            <p style="color:var(--text-muted);font-size:1.15rem;max-width:800px;margin:1.5rem 0">Consultoria técnica, projetos com ART, subestações e adequação normativa para indústrias, hospitais e grandes empreendimentos em <%= cityData.region %>.</p>
            <div style="display:flex;gap:1rem;flex-wrap:wrap; margin-top: 2rem;">
                <a href="/contato" class="btn btn-primary">Solicitar Consultoria Técnica</a>
                <a href="#especialidades" class="btn btn-ghost">Ver Especialidades</a>
            </div>
        </div>
    </section>

<!-- ═══ ESPECIALIDADES (Cards de Navegação) ═══ -->
<section class="section-padding" id="especialidades" style="background: var(--bg-primary); border-top: 1px solid var(--border-color);">
    <div class="container">
        <div class="section-separator fade-in"><%- include('partials/symbol') %> <span>ÁREAS DE ATUAÇÃO</span></div>
        <h2 class="fade-in" style="margin-bottom: 3rem;">Engenharia<br><span style="color:var(--accent-primary)">especializada.</span></h2>
        
        <div class="grid grid-cols-3" style="gap: 2rem;">
            <% 
               const engServices = Object.keys(locations.default.services).filter(key => {
                 const svc = locations.default.services[key];
                 return svc.category === 'engenharia' && isServiceEnabled(key) && key !== 'engenharia';
               });
               
               engServices.forEach(key => { 
                 const svc = (cityData.services && cityData.services[key]) || locations.default.services[key];
            %>
            <a href="<%= cityPrefix %>/solucoes/engenharia/<%= key %>" class="bracket-box fade-in" style="text-decoration: none; display: block; border-left: 4px solid var(--accent-primary); transition: transform 0.3s; padding: 2.5rem;">
                <h3 style="color: var(--text-main); margin-bottom: 1rem; font-size: 1.2rem;"><%= svc.label %> <i class="fas fa-arrow-right" style="font-size: 0.8rem; margin-left: 0.5rem; color: var(--accent-primary);"></i></h3>
                <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;"><%= svc.summary || svc.painPoint || 'Consultoria técnica e projetos com responsabilidade técnica.' %></p>
                <span style="display: inline-block; margin-top: 1.5rem; color: var(--accent-primary); font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase;">Explorar →</span>
            </a>
            <% }) %>
        </div>
    </div>
</section>

<!-- ═══ CONTEXTO TÉCNICO LOCAL ═══ -->
<% if (cityData.serviceContext) { %>
    <section class="section-padding" style="background: var(--bg-secondary); border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
        <div class="container">
            <div class="grid grid-cols-2" style="gap: 4rem; align-items: center;">
                <div class="fade-in">
                    <div class="section-separator"><%- include('partials/symbol') %> <span>FOCO REGIONAL</span></div>
                    <h2 style="margin-bottom: 2rem;">Engenharia Elétrica em <%= cityData.name %>:<br><span style="color:var(--accent-primary)">Atuação Direcionada</span></h2>
                    <div style="color: var(--text-muted); line-height: 1.7; font-size: 1.05rem;">
                        <%- cityData.serviceContext %>
                        <p style="margin-top: 1.5rem; font-weight: 600; color: var(--text-main);">Atendemos os principais bairros como <%= cityData.bairros %>.</p>
                    </div>
                </div>
                <div class="fade-in" style="position: relative;">
                     <div class="bracket-box" style="padding: 2rem; background: var(--bg-primary); border-color: var(--accent-primary);">
                        <h4 style="color: var(--accent-primary); margin-bottom: 1rem; font-family: var(--font-condensed); letter-spacing: 1px;">ÁREA DE COBERTURA</h4>
                        <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;">A Klyfe Electric mantém equipes técnicas dimensionadas para pronto atendimento em <strong><%= cityData.name %></strong> e municípios da <strong><%= cityData.region %></strong>, garantindo agilidade no planejamento e execução de obras de engenharia elétrica.</p>
                     </div>
                </div>
            </div>
        </div>
    </section>
<% } %>

<!-- Especialidades de Engenharia -->
<section class="section-padding" style="background:var(--bg-primary)">
    <div class="container fade-in">
        <div class="section-separator"><span>— ESPECIALIDADES —</span></div>
        <div class="grid grid-cols-2" style="gap:2rem">
            <div class="bracket-box" style="border-left:4px solid var(--accent-primary)">
                <h3 style="margin-bottom:1.5rem">Projetos & Consultoria</h3>
                <ul style="color:var(--text-muted);font-size:0.95rem">
                    <li style="margin-bottom:1rem"><strong>Projetos Elétricos Industriais</strong> — Dimensionamento de cargas e proteção.</li>
                    <li style="margin-bottom:1rem"><strong>Projetos de SPDA (Para-raios)</strong> — Proteção contra descargas atmosféricas <span class="badge-mono">NBR 5419</span>.</li>
                    <li style="margin-bottom:1rem"><strong>Subestações de Energia</strong> — Projetos, montagem e manutenção preventiva/corretiva.</li>
                    <li style="margin-bottom:1rem"><strong>Estudo de Seletividade</strong> — Coordenação de dispositivos de proteção.</li>
                    <li><strong>Consultoria em Eficiência Energética</strong> — Redução de custos operacionais.</li>
                </ul>
            </div>
            <div class="bracket-box" style="border-left:4px solid var(--accent-primary)">
                <h3 style="margin-bottom:1.5rem">Laudos & Normas</h3>
                <ul style="color:var(--text-muted);font-size:0.95rem">
                    <li style="margin-bottom:1rem"><strong>Prontuário das Instalações Elétricas (PIE)</strong> — Conformidade total <span class="badge-mono">NR-10</span>.</li>
                    <li style="margin-bottom:1rem"><strong>Laudo de Aterramento</strong> — Medição de continuidade e resistência.</li>
                    <li style="margin-bottom:1rem"><strong>Inspeção Termográfica</strong> — Identificação de pontos quentes em painéis.</li>
                    <li style="margin-bottom:1rem"><strong>Análise de Qualidade de Energia</strong> — Estudo de harmônicas e fator de potência.</li>
                    <li><strong>Laudos para o Corpo de Bombeiros</strong> — Renovação de AVCB.</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Diferencial Técnico -->
<section class="section-padding bg-blueprint">
    <div class="container">
        <div class="grid grid-cols-2" style="align-items:center;gap:4rem">
            <div class="fade-in">
                <h2 style="margin-bottom:1.5rem">Responsabilidade Técnica<br>em cada detalhe.</h2>
                <p style="color:var(--text-muted);line-height:1.8">Na Klyfe Electric, a engenharia não é apenas um papel assinado. É a aplicação rigorosa de normas internacionais e brasileiras para garantir que seu empreendimento opere com 100% de disponibilidade e segurança.</p>
                <div style="margin-top:2rem;display:flex;gap:2rem">
                    <div><h4 style="color:var(--accent-primary)">+200</h4><p style="font-size:0.8rem;color:var(--text-muted)">Projetos com ART</p></div>
                    <div><h4 style="color:var(--accent-primary)">100%</h4><p style="font-size:0.8rem;color:var(--text-muted)">Conformidade NR-10</p></div>
                </div>
            </div>
            <div class="bracket-box fade-in" style="padding:3rem">
                <h3>Setores que Atendemos:</h3>
                <ul style="margin-top:1.5rem;color:var(--text-muted)">
                    <li style="margin-bottom:0.8rem"><i class="fas fa-industry" style="color:var(--accent-primary);margin-right:10px"></i> Indústrias e Parques Fabris</li>
                    <li style="margin-bottom:0.8rem"><i class="fas fa-hospital" style="color:var(--accent-primary);margin-right:10px"></i> Hospitais e Clínicas</li>
                    <li style="margin-bottom:0.8rem"><i class="fas fa-building" style="color:var(--accent-primary);margin-right:10px"></i> Condomínios e Prédios Comerciais</li>
                    <li><i class="fas fa-shopping-cart" style="color:var(--accent-primary);margin-right:10px"></i> Supermercados e Shoppings</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- ═══ FAQ ═══ -->
<% if (cityData.faqExtra) { %>
    <section class="section-padding" style="background: var(--bg-secondary);">
        <div class="container" style="max-width: 800px;">
            <div class="section-separator fade-in" style="justify-content: center;"><%- include('partials/symbol') %> <span>DÚVIDAS FREQUENTES</span></div>
            <h2 style="text-align: center; margin-bottom: 4rem;">Dúvidas Frequentes sobre Engenharia em <br><span style="color:var(--accent-primary)"><%= cityData.name %></span></h2>
            
            <div class="faq-accordion fade-in">
                <div class="faq-item" style="padding: 1.5rem 0; border-bottom: 1px solid var(--border-color);">
                    <button class="faq-question" style="width: 100%; display: flex; justify-content: space-between; align-items: center; background: none; border: none; color: var(--text-main); font-size: 1.1rem; font-weight: 600; text-align: left; cursor: pointer;">
                        <%= cityData.faqExtra.question %>
                        <i class="fas fa-plus" style="font-size: 0.8rem; color: var(--accent-primary);"></i>
                    </button>
                    <div class="faq-answer" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out;">
                        <p style="padding-top: 1rem; color: var(--text-muted); line-height: 1.6;"><%= cityData.faqExtra.answer %></p>
                    </div>
                </div>
            </div>
        </div>
    </section>
<% } %>

<!-- ═══ LINK CRUZADO ENTRE CIDADES ═══ -->
<section style="padding: 2rem 0; background: var(--bg-primary); border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
    <div class="container" style="text-align: center;">
        <p style="color: var(--text-muted); font-size: 0.95rem;">
            <% if (cityKey === 'default') { %>
                A Klyfe Electric possui forte atuação regional com equipes dedicadas em 
                <a href="/campina-grande/solucoes/engenharia" style="color: var(--accent-primary); text-decoration: none; font-weight: 600;">Campina Grande</a> e 
                <a href="/joao-pessoa/solucoes/engenharia" style="color: var(--accent-primary); text-decoration: none; font-weight: 600;">João Pessoa</a>.
            <% } else { %>
                Nossa equipe de engenharia também atende a região de 
                <a href="<%= alternateUrl %>" style="color: var(--accent-primary); text-decoration: none; font-weight: 600;">
                    <%= alternateCityName %>
                </a>.
            <% } %>
        </p>
    </div>
</section>


<!-- CTA -->
<section class="cta-banner">
    <div class="container fade-in" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:2rem">
        <div><h2>Inicie seu projeto de<br>Engenharia hoje.</h2><p>Fale diretamente com nossa equipe de engenheiros em <%= cityData.name %>.</p></div>
        <div style="display:flex;gap:1rem;flex-wrap:wrap">
            <a href="/contato" class="btn-dark">Agendar Consultoria</a>
            <% const waHubMsg = (typeof cityData !== 'undefined' && cityData.whatsappMessage) ? cityData.whatsappMessage : 'Olá! Gostaria de solicitar um orçamento.'; %>
            <a href="https://wa.me/5583991330972?text=<%= encodeURIComponent(waHubMsg) %>" target="_blank" rel="noopener" class="btn-dark" style="background:transparent;border:2px solid var(--bg-primary);color:var(--bg-primary)"><i class="fab fa-whatsapp"></i> <%= cityData.cta || '(83) 99133-0972' %></a>
        </div>

    </div>
</section>

</main>
<%- include('partials/whatsapp') %>
<%- include('partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
