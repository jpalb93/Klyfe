        <div style="display:flex;gap:1rem;flex-wrap:wrap">
            <a href="https://wa.me/5583991330972" class="btn-dark" style="background: var(--bg-primary); color: var(--text-main); border: none;">Solicitar Orçamento de Automação</a>
        </div>
    </div>
</section>

</main>
